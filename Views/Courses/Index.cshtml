@model IEnumerable<Course>
@{
    ViewData["Title"] = "Dersler";
}

<section class="page-title">
    <div>
        <p class="eyebrow">Ders yonetimi</p>
        <h1>Dersler</h1>
        <p class="text-muted mb-0">Donem derslerini ekle, duzenle ve takip et.</p>
    </div>
    <div class="title-actions">
        <a class="btn btn-primary" asp-action="Create">Ders Ekle</a>
    </div>
</section>

<section class="content-panel">
    <div class="toolbar">
        <label class="form-label mb-0" for="courseSearch">Ders ara</label>
        <input class="form-control" id="courseSearch" type="search" placeholder="Ders adi veya ogretim uyesi" />
    </div>

    <div class="table-responsive">
        <table class="table align-middle app-table" id="coursesTable">
            <thead>
                <tr>
                    <th>Ders</th>
                    <th>Ogretim Uyesi</th>
                    <th>Kredi</th>
                    <th>Gorev</th>
                    <th>Sinav</th>
                    <th class="text-end">Islemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in Model)
                {
                    <tr>
                        <td class="fw-semibold">@course.Name</td>
                        <td>@(course.Instructor ?? "-")</td>
                        <td>@course.Credit</td>
                        <td>@course.StudyTasks.Count</td>
                        <td>@course.Exams.Count</td>
                        <td class="text-end table-actions">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@course.Id">Duzenle</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@course.Id">Sil</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
