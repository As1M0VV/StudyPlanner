@model IEnumerable<StudyTask>
@{
    ViewData["Title"] = "Calisma Plani";
    var status = ViewBag.Status as string ?? "all";
    var query = ViewBag.Query as string ?? string.Empty;
}

<section class="page-title">
    <div>
        <p class="eyebrow">Planlama</p>
        <h1>Calisma Plani</h1>
        <p class="text-muted mb-0">Derslere bagli calisma gorevlerini takip et.</p>
    </div>
    <div class="title-actions">
        <a class="btn btn-primary" asp-action="Create">Gorev Ekle</a>
    </div>
</section>

<section class="content-panel">
    <form class="toolbar toolbar-grid" asp-action="Index" method="get">
        <div>
            <label class="form-label" for="taskSearch">Ara</label>
            <input class="form-control" id="taskSearch" type="search" name="q" value="@query" placeholder="Gorev veya ders adi" />
        </div>
        <div>
            <label class="form-label" for="status">Durum</label>
            <select class="form-select" id="status" name="status">
                <option value="all" selected="@(status == "all" ? "selected" : null)">Tum gorevler</option>
                <option value="open" selected="@(status == "open" ? "selected" : null)">Acik</option>
                <option value="completed" selected="@(status == "completed" ? "selected" : null)">Tamamlanan</option>
            </select>
        </div>
        <div class="toolbar-submit">
            <button type="submit" class="btn btn-outline-primary">Filtrele</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table align-middle app-table" id="tasksTable">
            <thead>
                <tr>
                    <th>Gorev</th>
                    <th>Ders</th>
                    <th>Tarih</th>
                    <th>Sure</th>
                    <th>Durum</th>
                    <th class="text-end">Islemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var task in Model)
                {
                    <tr data-completed="@(task.IsCompleted.ToString().ToLowerInvariant())">
                        <td>
                            <strong>@task.Title</strong>
                            @if (!string.IsNullOrWhiteSpace(task.Description))
                            {
                                <span class="table-subtext">@task.Description</span>
                            }
                        </td>
                        <td>@task.Course?.Name</td>
                        <td>@task.StudyDate.ToString("dd.MM.yyyy")</td>
                        <td>@task.DurationMinutes dk</td>
                        <td>
                            @if (task.IsCompleted)
                            {
                                <span class="badge text-bg-success">Tamamlandi</span>
                            }
                            else
                            {
                                <span class="badge text-bg-warning">Acik</span>
                            }
                        </td>
                        <td class="text-end table-actions">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@task.Id">Duzenle</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@task.Id">Sil</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
