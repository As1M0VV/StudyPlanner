@model ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<section class="page-title">
    <div>
        <p class="eyebrow">Sistem</p>
        <h1>Bir hata olustu</h1>
        <p class="text-muted mb-0">Istek islenirken beklenmeyen bir sorun yasandi.</p>
    </div>
</section>

@if (Model.ShowRequestId)
{
    <div class="alert alert-warning">
        Request ID: <code>@Model.RequestId</code>
    </div>
}
