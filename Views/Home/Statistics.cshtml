@model StatisticsViewModel
@{
    ViewData["Title"] = "Istatistikler";
    var totalHours = Math.Round(Model.TotalStudyMinutes / 60.0, 1);
}

<section class="page-title">
    <div>
        <p class="eyebrow">Analiz</p>
        <h1>Istatistikler</h1>
        <p class="text-muted mb-0">Calisma surelerini ve ders bazli ilerlemeyi takip et.</p>
    </div>
</section>

<section class="metric-grid">
    <article class="metric-card accent-blue">
        <span>Calisma</span>
        <strong>@totalHours</strong>
        <small>Toplam saat</small>
    </article>
    <article class="metric-card accent-green">
        <span>Tamamlanan</span>
        <strong>@Model.CompletedTasks</strong>
        <small>Bitirilen gorev</small>
    </article>
    <article class="metric-card accent-orange">
        <span>Acik</span>
        <strong>@Model.OpenTasks</strong>
        <small>Devam eden gorev</small>
    </article>
    <article class="metric-card accent-red">
        <span>Sinav</span>
        <strong>@Model.ExamCount</strong>
        <small>Kayitli sinav</small>
    </article>
</section>

<section class="content-panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">Ders dagilimi</p>
            <h2>Derse gore calisma</h2>
        </div>
    </div>

    @if (Model.CourseStats.Any())
    {
        <div class="stats-list">
            @foreach (var stat in Model.CourseStats)
            {
                <div class="stat-row">
                    <div class="stat-row-header">
                        <div>
                            <strong>@stat.CourseName</strong>
                            <span>@stat.CompletedTasks tamamlanan gorev, @stat.UpcomingExams yaklasan sinav</span>
                        </div>
                        <span>@stat.TotalMinutes dk</span>
                    </div>
                    <div class="progress" role="progressbar" aria-label="@stat.CourseName calisma orani" aria-valuenow="@stat.Percentage" aria-valuemin="0" aria-valuemax="100">
                        <div class="progress-bar" style="width: @stat.Percentage%">%@stat.Percentage</div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="empty-state">Henuz istatistik olusturacak ders bulunmuyor.</p>
    }
</section>
